# vscode
.vscode 

# Intellij
*.iml
.idea

# npm
node_modules

# Don't include the compiled main.js file in the repo.
# They should be uploaded to GitHub releases instead.
main.js

# Exclude sourcemaps
*.map

# obsidian
data.json

# Exclude macOS Finder (System Explorer) View States
.DS_Store

# Example vault: keep the demo notes + enabled-plugins list, but ignore the
# symlinked build (npm run example) and Obsidian's volatile per-machine state.
example-vault/.obsidian/*
!example-vault/.obsidian/community-plugins.json
